# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-key>

# App
EXPO_PUBLIC_APP_URL=http://localhost:8081


# Membership
EXPO_PUBLIC_MEMBERSHIP_AMOUNT=1500
EXPO_PUBLIC_MEMBERSHIP_CURRENCY=INR

# Supabase Edge Function secrets (set via Supabase Dashboard, not in client .env):
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# APP_URL=https://your-site.example
#RAZORPAY_KEY_ID=
#RAZORPAY_KEY_SECRET=
#RAZORPAY_WEBHOOK_SECRET=
# REGISTRATION_FEE_AMOUNT_INR=1500
# REGISTRATION_FEE_CURRENCY=INR
